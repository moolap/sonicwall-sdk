# Copy to .env at the repo root (gitignored) for local live-device validation.
#
#   cp .env.example .env
#   # edit .env with your lab appliance credentials
#
# Used by smoke_test.py, validate_write_crud.py, and pytest integration tests.

SONICWALL_HOST=192.168.0.1
SONICWALL_USER=admin
SONICWALL_PASS=

# Optional: enable destructive write CRUD integration tests
# SONICWALL_INTEGRATION_WRITE=1
