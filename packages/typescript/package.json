{
  "name": "@sonicwall/sdk",
  "version": "0.1.0",
  "description": "TypeScript/JavaScript SDK for the SonicOS REST API",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "ky": "^1.7.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.0.0",
    "msw": "^2.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "sonicwall",
    "sonicos",
    "firewall",
    "sdk",
    "api",
    "networking"
  ],
  "license": "Apache-2.0",
  "homepage": "https://gitlab.com/gandiva-tech/sonicwall-sdk",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/gandiva-tech/sonicwall-sdk.git",
    "directory": "packages/typescript"
  }
}